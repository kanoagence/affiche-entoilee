---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticles, formatDate } from '../../lib/data';

const articles = await getArticles(true);
---

<BaseLayout
  title="Revue — Hervé Affiches"
  description="Notes de l'atelier sur l'histoire de l'affiche, les techniques de restauration et les grands maîtres de l'art graphique français."
>
  <!-- Header -->
  <section
    style="padding: 10rem 3rem 5rem; background: linear-gradient(160deg, var(--cream) 0%, var(--ivory) 100%); border-bottom: 1px solid rgba(139,111,71,0.2);"
  >
    <div style="max-width: 700px; margin: 0 auto; text-align: center;">
      <p class="section-eyebrow" style="justify-content:center;">La revue</p>
      <h1 style="font-size: clamp(2rem, 4vw, 3rem); margin: 1rem 0 1.5rem;">
        Articles & expertise
      </h1>
      <p style="font-size: 1.1rem; color: var(--sepia); font-weight: 300; line-height: 1.8;">
        Notes de l'atelier sur l'histoire de l'affiche française,
        les techniques de restauration et les grands maîtres de l'art graphique.
      </p>
    </div>
  </section>

  <!-- Articles grid -->
  <section class="section">
    {articles.length === 0 ? (
      <div style="text-align: center; color: var(--sepia); padding: 4rem 0;">
        <p style="font-size: 1.2rem;">Aucun article publié pour le moment.</p>
      </div>
    ) : (
      <div class="blog-grid">
        {articles.map((article) => (
          <a
            href={`/blog/${article.id}`}
            style="text-decoration: none; color: inherit; display: block;"
          >
            <article style="background: var(--ivory); border: 1px solid rgba(139,111,71,0.15); padding: 2rem; height: 100%; transition: box-shadow 0.2s; cursor: pointer;">
              <p style="font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sepia); opacity: 0.6; margin-bottom: 1rem;">
                {formatDate(article.created_at)}
              </p>
              <h2 style="font-family: 'Playfair Display', serif; font-size: 1.2rem; line-height: 1.3; color: var(--dark); margin-bottom: 0.75rem;">
                {article.titre}
              </h2>
              {article.resume && (
                <p style="font-size: 0.95rem; color: var(--sepia); line-height: 1.6; font-weight: 300;">
                  {article.resume}
                </p>
              )}
              <p style="margin-top: 1.25rem; font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--rust);">
                Lire →
              </p>
            </article>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
