---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticle, formatDate } from '../../lib/data';

const { slug: id } = Astro.params;

if (!id) {
  return Astro.redirect('/blog');
}

const article = await getArticle(id);

if (!article || !article.publie) {
  return new Response(null, { status: 404 });
}
---

<BaseLayout
  title={`${article.titre} — Revue Hervé Affiches`}
  description={article.resume ?? undefined}
>
  <!-- Article header -->
  <section
    style="padding: 8rem 3rem 4rem; background: linear-gradient(160deg, var(--cream) 0%, var(--ivory) 100%);"
  >
    <div style="max-width: 720px; margin: 0 auto;">
      <a
        href="/blog"
        style="font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sepia); display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 2rem; transition: color 0.2s;"
      >
        ← La revue
      </a>

      <p style="font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sepia); opacity: 0.6; margin-bottom: 0.5rem;">
        {formatDate(article.created_at)}
      </p>
      <h1 style="font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 1.15; margin: 0.75rem 0 1.25rem;">
        {article.titre}
      </h1>
      {article.resume && (
        <p style="font-size: 1.2rem; color: var(--sepia); font-weight: 300; line-height: 1.7; font-style: italic;">
          {article.resume}
        </p>
      )}
    </div>
  </section>

  <!-- Article content -->
  <article style="padding: 4rem 3rem 6rem; max-width: 720px; margin: 0 auto;">
    {article.contenu ? (
      <div style="font-size: 1.05rem; color: var(--sepia); line-height: 1.8; font-weight: 300; white-space: pre-wrap;">
        {article.contenu}
      </div>
    ) : (
      <p style="color: var(--sepia); font-style: italic; opacity: 0.6;">Contenu non disponible.</p>
    )}

    <!-- Footer de l'article -->
    <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(139,111,71,0.2); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <a
        href="/blog"
        style="font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sepia);"
      >
        ← Tous les articles
      </a>
      <a
        href="/contact"
        class="btn-secondary"
        style="font-size: 0.65rem;"
      >
        Contacter l'atelier
      </a>
    </div>
  </article>
</BaseLayout>
