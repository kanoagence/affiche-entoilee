---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { writeFile } from 'node:fs/promises';
import { join } from 'node:path';

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();

    const titre = (data.get('titre') as string)?.trim();
    const resume = (data.get('resume') as string)?.trim();
    const dateStr = data.get('date') as string;
    const publie = data.get('publie') === 'on';
    const contenu = (data.get('contenu') as string)?.trim();

    if (!titre || !resume || !dateStr || !contenu) {
      error = 'Les champs titre, résumé, date et contenu sont obligatoires.';
    } else {
      // Generate slug
      const slug = titre
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');

      const frontmatter = [
        '---',
        `titre: "${titre.replace(/"/g, '\\"')}"`,
        `resume: "${resume.replace(/"/g, '\\"')}"`,
        `date: ${dateStr}`,
        `publie: ${publie}`,
        '---',
        '',
        contenu,
      ].join('\n');

      const contentDir = join(process.cwd(), 'src', 'content', 'blog');
      const filePath = join(contentDir, `${slug}.md`);
      await writeFile(filePath, frontmatter, 'utf-8');

      return Astro.redirect('/admin/blog?success=created');
    }
  } catch (e) {
    console.error(e);
    error = 'Erreur lors de la création de l\'article.';
  }
}

const today = new Date().toISOString().split('T')[0];
---

<AdminLayout title="Nouvel article — Admin Hervé Affiches" activeSection="blog">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(245,240,232,0.08);">
    <h1 class="admin-page-title" style="margin: 0; border: none; padding: 0;">Nouvel article</h1>
    <a href="/admin/blog" class="admin-btn admin-btn-secondary">← Retour</a>
  </div>

  {error && <div class="alert alert-error">{error}</div>}

  <form method="POST" action="/admin/blog/nouveau">
    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 2rem; align-items: start;">
      <!-- Main content -->
      <div>
        <div class="admin-card">
          <div class="admin-form-group">
            <label class="admin-label" for="titre">Titre *</label>
            <input
              class="admin-input"
              type="text"
              id="titre"
              name="titre"
              required
              placeholder="Titre de l'article..."
              style="font-size: 1.1rem; font-family: 'Playfair Display', serif;"
            />
          </div>

          <div class="admin-form-group">
            <label class="admin-label" for="resume">Résumé / Chapô *</label>
            <textarea
              class="admin-textarea"
              id="resume"
              name="resume"
              required
              rows="2"
              placeholder="Court résumé affiché sur la liste et les aperçus..."
            ></textarea>
          </div>

          <div class="admin-form-group">
            <label class="admin-label" for="contenu">
              Contenu (Markdown) *
              <a
                href="https://www.markdownguide.org/basic-syntax/"
                target="_blank"
                rel="noopener"
                style="color: rgba(245,240,232,0.3); font-size: 0.55rem; margin-left: 0.5rem; transition: color 0.2s;"
              >
                Guide Markdown ↗
              </a>
            </label>
            <textarea
              class="admin-textarea"
              id="contenu"
              name="contenu"
              required
              rows="20"
              placeholder="Rédigez votre article en Markdown...

## Titre de section

Paragraphe...

- Item de liste
- Item de liste"
              style="font-family: 'DM Mono', monospace; font-size: 0.82rem; line-height: 1.6;"
            ></textarea>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div>
        <div class="admin-card">
          <h2 style="font-family: 'DM Mono', monospace; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,240,232,0.5); margin-bottom: 1.5rem;">
            Publication
          </h2>

          <div class="admin-form-group">
            <label class="admin-label" for="date">Date de publication *</label>
            <input class="admin-input" type="date" id="date" name="date" value={today} required />
          </div>

          <div class="admin-form-group" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem; background: rgba(245,240,232,0.04); border: 1px solid rgba(245,240,232,0.08);">
            <input type="checkbox" id="publie" name="publie" style="width: 16px; height: 16px; accent-color: var(--rust);" />
            <div>
              <label class="admin-label" for="publie" style="margin: 0;">Publier maintenant</label>
              <p style="font-size: 0.7rem; color: rgba(245,240,232,0.3); margin-top: 0.2rem;">
                Si décoché, l'article sera enregistré comme brouillon.
              </p>
            </div>
          </div>
        </div>

        <div style="margin-top: 1rem;">
          <button type="submit" class="admin-btn admin-btn-primary" style="width: 100%; text-align: center; padding: 0.875rem; font-size: 0.72rem;">
            Créer l'article
          </button>
        </div>
      </div>
    </div>
  </form>
</AdminLayout>
