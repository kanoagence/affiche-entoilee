---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getArticleAdmin, updateArticle, deleteArticle } from '../../../lib/data';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/blog');
}

const article = await getArticleAdmin(id);

if (!article) {
  return new Response(null, { status: 404 });
}

let error = '';

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('_action') as string;

  if (action === 'delete') {
    const ok = await deleteArticle(id);
    if (ok) {
      return Astro.redirect('/admin/blog?success=deleted');
    } else {
      error = 'Erreur lors de la suppression.';
    }
  } else {
    try {
      const titre = (data.get('titre') as string)?.trim();
      const resume = (data.get('resume') as string)?.trim() || null;
      const publie = data.get('publie') === 'on';
      const contenu = (data.get('contenu') as string)?.trim() || null;

      if (!titre) {
        error = 'Le champ titre est obligatoire.';
      } else {
        const ok = await updateArticle(id, { titre, resume, contenu, publie });

        if (!ok) {
          error = 'Erreur lors de la mise à jour. Vérifiez les logs.';
        } else {
          return Astro.redirect('/admin/blog?success=updated');
        }
      }
    } catch (e) {
      console.error(e);
      error = 'Erreur lors de la mise à jour.';
    }
  }
}
---

<AdminLayout title={`${article.titre} — Admin Blog`} activeSection="blog">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(245,240,232,0.08);">
    <h1 class="admin-page-title" style="margin: 0; border: none; padding: 0; font-size: 1.25rem;">
      Modifier — <em style="color: var(--gold-light);">{article.titre}</em>
    </h1>
    <div style="display: flex; gap: 0.5rem;">
      {article.publie && (
        <a href={`/blog/${id}`} target="_blank" class="admin-btn admin-btn-secondary" style="font-size: 0.6rem;">↗ Voir</a>
      )}
      <a href="/admin/blog" class="admin-btn admin-btn-secondary">← Retour</a>
    </div>
  </div>

  {error && <div class="alert alert-error">{error}</div>}

  <form method="POST" action={`/admin/blog/${id}`}>
    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 2rem; align-items: start;">
      <!-- Contenu principal -->
      <div>
        <div class="admin-card">
          <div class="admin-form-group">
            <label class="admin-label" for="titre">Titre *</label>
            <input
              class="admin-input"
              type="text"
              id="titre"
              name="titre"
              value={article.titre}
              required
              style="font-size: 1.1rem; font-family: 'Playfair Display', serif;"
            />
          </div>

          <div class="admin-form-group">
            <label class="admin-label" for="resume">Résumé</label>
            <textarea class="admin-textarea" id="resume" name="resume" rows="2">{article.resume ?? ''}</textarea>
          </div>

          <div class="admin-form-group">
            <label class="admin-label" for="contenu">Contenu *</label>
            <textarea
              class="admin-textarea"
              id="contenu"
              name="contenu"
              required
              rows="22"
              style="font-family: 'DM Mono', monospace; font-size: 0.82rem; line-height: 1.6;"
            >{article.contenu ?? ''}</textarea>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div>
        <div class="admin-card">
          <h2 style="font-family: 'DM Mono', monospace; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,240,232,0.5); margin-bottom: 1.5rem;">
            Publication
          </h2>

          <div class="admin-form-group" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem; background: rgba(245,240,232,0.04); border: 1px solid rgba(245,240,232,0.08);">
            <input
              type="checkbox"
              id="publie"
              name="publie"
              checked={article.publie}
              style="width: 16px; height: 16px; accent-color: var(--rust);"
            />
            <div>
              <label class="admin-label" for="publie" style="margin: 0;">Article publié</label>
              <p style="font-size: 0.7rem; color: rgba(245,240,232,0.3); margin-top: 0.2rem;">
                Visible sur le site public.
              </p>
            </div>
          </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem;">
          <button type="submit" class="admin-btn admin-btn-primary" style="width: 100%; text-align: center; padding: 0.875rem; font-size: 0.72rem;">
            Enregistrer
          </button>
        </div>
      </div>
    </div>
  </form>

  <!-- Zone dangereuse -->
  <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(196,98,45,0.2);">
    <h3 style="font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(196,98,45,0.6); margin-bottom: 1rem;">
      Zone dangereuse
    </h3>
    <form
      method="POST"
      action={`/admin/blog/${id}`}
      onsubmit="return confirm('Supprimer cet article définitivement ?')"
    >
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" class="admin-btn admin-btn-danger">
        Supprimer cet article
      </button>
    </form>
  </div>
</AdminLayout>
