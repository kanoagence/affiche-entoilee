---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getProduitsAdmin, etatLabel, stockTotal } from '../../../lib/data';

const produits = await getProduitsAdmin();
const successMsg = Astro.url.searchParams.get('success');
---

<AdminLayout title="Produits — Admin Hervé Affiches" activeSection="produits">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(245,240,232,0.08);">
    <h1 class="admin-page-title" style="margin: 0; border: none; padding: 0;">
      Produits <span style="font-size: 1rem; color: rgba(245,240,232,0.4);">({produits.length})</span>
    </h1>
    <div style="display: flex; gap: 0.75rem;">
      <a href="/admin/produits/import" class="admin-btn admin-btn-secondary">↑ Importer Excel</a>
      <a href="/admin/produits/nouveau" class="admin-btn admin-btn-primary">+ Nouveau produit</a>
    </div>
  </div>

  {successMsg === 'created' && <div class="alert alert-success">Produit créé avec succès.</div>}
  {successMsg === 'updated' && <div class="alert alert-success">Produit mis à jour avec succès.</div>}
  {successMsg === 'deleted' && <div class="alert alert-success">Produit supprimé.</div>}

  {produits.length === 0 ? (
    <div style="text-align: center; padding: 4rem; color: rgba(245,240,232,0.4);">
      <p style="font-size: 1.1rem; margin-bottom: 1rem;">Aucun produit pour le moment.</p>
      <a href="/admin/produits/nouveau" class="admin-btn admin-btn-primary">Créer le premier produit</a>
    </div>
  ) : (
    <div class="admin-card" style="padding: 0;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Réf.</th>
            <th>Titre</th>
            <th>Affichiste</th>
            <th>Année</th>
            <th>Catégorie</th>
            <th>État</th>
            <th>Stk E/P/C</th>
            <th>Dispo</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {produits.map((p) => (
            <tr>
              <td style="font-family: 'DM Mono', monospace; font-size: 0.7rem; opacity: 0.5;">{p.ref ?? '—'}</td>
              <td><strong style="color: var(--cream);">{p.titre}</strong></td>
              <td style="opacity: 0.7;">{p.affichiste ?? '—'}</td>
              <td style="font-family: 'DM Mono', monospace; font-size: 0.8rem; opacity: 0.7;">{p.annee ?? '—'}</td>
              <td style="opacity: 0.7;">{p.categorie ?? '—'}</td>
              <td>
                <span class="admin-badge" style={
                  p.etat === 'entoilee' ? 'background: rgba(196,98,45,0.2); color: var(--rust);' :
                  p.etat === 'restauree' ? 'background: rgba(184,150,46,0.2); color: var(--gold-light);' :
                  'background: rgba(245,240,232,0.08); color: rgba(245,240,232,0.5);'
                }>
                  {etatLabel(p.etat)}
                </span>
              </td>
              <td style="font-family: 'DM Mono', monospace; font-size: 0.75rem; opacity: 0.7;">
                {p.stk_e}/{p.stk_p}/{p.stk_c}
              </td>
              <td>
                <span class="status-dot" style={p.disponible ? 'background: #4ade80;' : 'background: var(--rust);'}></span>
                <span style="font-size: 0.8rem; opacity: 0.6;">{p.disponible ? 'Oui' : 'Non'}</span>
              </td>
              <td>
                <div style="display: flex; gap: 0.5rem;">
                  <a href={`/admin/produits/${p.id}`} class="admin-btn admin-btn-secondary" style="padding: 0.25rem 0.6rem; font-size: 0.58rem;">
                    Modifier
                  </a>
                  <a href={`/produits/${p.id}`} target="_blank" class="admin-btn admin-btn-secondary" style="padding: 0.25rem 0.6rem; font-size: 0.58rem; opacity: 0.5;">
                    ↗
                  </a>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
