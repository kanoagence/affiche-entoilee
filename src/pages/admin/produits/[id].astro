---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getProduit, etatLabel } from '../../../lib/data';
import { writeFile, unlink } from 'node:fs/promises';
import { join } from 'node:path';
import { existsSync } from 'node:fs';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/produits');
}

const produit = await getProduit(id);

if (!produit) {
  return new Response(null, { status: 404 });
}

let error = '';

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('_action') as string;

  if (action === 'delete') {
    try {
      const filePath = join(process.cwd(), 'src', 'content', 'produits', `${id}.json`);
      if (existsSync(filePath)) {
        await unlink(filePath);
      }
      return Astro.redirect('/admin/produits?success=deleted');
    } catch (e) {
      error = 'Erreur lors de la suppression.';
    }
  } else {
    // Update
    try {
      const titre = (data.get('titre') as string)?.trim();
      const description = (data.get('description') as string)?.trim();
      const annee = (data.get('annee') as string)?.trim();
      const dimensions = (data.get('dimensions') as string)?.trim() || undefined;
      const etat = data.get('etat') as string;
      const prixRaw = data.get('prix') as string;
      const prix = prixRaw ? parseInt(prixRaw, 10) : undefined;
      const surDevis = data.get('surDevis') === 'on';
      const disponible = data.get('disponible') !== 'off';
      const artiste = (data.get('artiste') as string)?.trim() || undefined;
      const imprimeur = (data.get('imprimeur') as string)?.trim() || undefined;

      if (!titre || !description || !annee || !etat) {
        error = 'Les champs obligatoires sont manquants.';
      } else {
        const updatedData = {
          titre,
          description,
          annee,
          ...(dimensions && { dimensions }),
          etat,
          ...(prix && !surDevis && { prix }),
          surDevis,
          disponible,
          images: produit.images ?? [],
          ...(artiste && { artiste }),
          ...(imprimeur && { imprimeur }),
        };

        const filePath = join(process.cwd(), 'src', 'content', 'produits', `${id}.json`);
        await writeFile(filePath, JSON.stringify(updatedData, null, 2), 'utf-8');
        return Astro.redirect('/admin/produits?success=updated');
      }
    } catch (e) {
      error = 'Erreur lors de la mise à jour.';
    }
  }
}
---

<AdminLayout title={`${produit.titre} — Admin Hervé Affiches`} activeSection="produits">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(245,240,232,0.08);">
    <h1 class="admin-page-title" style="margin: 0; border: none; padding: 0; font-size: 1.25rem;">
      Modifier — <em style="color: var(--gold-light);">{produit.titre}</em>
    </h1>
    <div style="display: flex; gap: 0.5rem;">
      <a href={`/produits/${id}`} target="_blank" class="admin-btn admin-btn-secondary" style="font-size: 0.6rem;">↗ Voir</a>
      <a href="/admin/produits" class="admin-btn admin-btn-secondary">← Retour</a>
    </div>
  </div>

  {error && <div class="alert alert-error">{error}</div>}

  <form method="POST" action={`/admin/produits/${id}`}>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
      <div>
        <div class="admin-card">
          <h2 style="font-family: 'DM Mono', monospace; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,240,232,0.5); margin-bottom: 1.5rem;">
            Informations principales
          </h2>

          <div class="admin-form-group">
            <label class="admin-label" for="titre">Titre *</label>
            <input class="admin-input" type="text" id="titre" name="titre" value={produit.titre} required />
          </div>

          <div class="admin-form-group">
            <label class="admin-label" for="description">Description *</label>
            <textarea class="admin-textarea" id="description" name="description" required rows="4">{produit.description}</textarea>
          </div>

          <div class="admin-grid-2">
            <div class="admin-form-group">
              <label class="admin-label" for="annee">Année *</label>
              <input class="admin-input" type="text" id="annee" name="annee" value={produit.annee} required />
            </div>
            <div class="admin-form-group">
              <label class="admin-label" for="dimensions">Dimensions</label>
              <input class="admin-input" type="text" id="dimensions" name="dimensions" value={produit.dimensions ?? ''} />
            </div>
          </div>

          <div class="admin-grid-2">
            <div class="admin-form-group">
              <label class="admin-label" for="artiste">Artiste</label>
              <input class="admin-input" type="text" id="artiste" name="artiste" value={produit.artiste ?? ''} />
            </div>
            <div class="admin-form-group">
              <label class="admin-label" for="imprimeur">Imprimeur</label>
              <input class="admin-input" type="text" id="imprimeur" name="imprimeur" value={produit.imprimeur ?? ''} />
            </div>
          </div>
        </div>
      </div>

      <div>
        <div class="admin-card">
          <h2 style="font-family: 'DM Mono', monospace; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,240,232,0.5); margin-bottom: 1.5rem;">
            État & Prix
          </h2>

          <div class="admin-form-group">
            <label class="admin-label" for="etat">État *</label>
            <select class="admin-select" id="etat" name="etat" required>
              <option value="entoilee" selected={produit.etat === 'entoilee'}>Entoilée</option>
              <option value="restauree" selected={produit.etat === 'restauree'}>Restaurée</option>
              <option value="a-restaurer" selected={produit.etat === 'a-restaurer'}>À restaurer</option>
            </select>
          </div>

          <div class="admin-form-group">
            <label class="admin-label" for="prix">Prix (€)</label>
            <input class="admin-input" type="number" id="prix" name="prix" value={produit.prix ?? ''} min="0" />
          </div>

          <div class="admin-form-group" style="display: flex; align-items: center; gap: 0.75rem;">
            <input type="checkbox" id="surDevis" name="surDevis" checked={produit.surDevis} style="width: 16px; height: 16px; accent-color: var(--rust);" />
            <label class="admin-label" for="surDevis" style="margin: 0;">Sur devis uniquement</label>
          </div>

          <div class="admin-form-group" style="display: flex; align-items: center; gap: 0.75rem;">
            <input type="checkbox" id="disponible" name="disponible" checked={produit.disponible} style="width: 16px; height: 16px; accent-color: var(--rust);" />
            <label class="admin-label" for="disponible" style="margin: 0;">Disponible à la vente</label>
          </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem;">
          <button type="submit" class="admin-btn admin-btn-primary" style="width: 100%; text-align: center; padding: 0.875rem; font-size: 0.72rem;">
            Enregistrer les modifications
          </button>
        </div>
      </div>
    </div>
  </form>

  <!-- Delete zone -->
  <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(196,98,45,0.2);">
    <h3 style="font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(196,98,45,0.6); margin-bottom: 1rem;">
      Zone dangereuse
    </h3>
    <form
      method="POST"
      action={`/admin/produits/${id}`}
      onsubmit="return confirm('Supprimer ce produit définitivement ?')"
    >
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" class="admin-btn admin-btn-danger">
        Supprimer ce produit
      </button>
    </form>
  </div>
</AdminLayout>
