---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProduits } from '../../lib/data';

const produits = await getProduits();

function posterColor(titre: string): string {
  const p = [
    ['#4A3728','#C4622D'],['#2D3D5C','#2D7A9A'],['#3D2E5C','#8A4A9A'],
    ['#2E4A3D','#4A8A6A'],['#4A4228','#9A8A2D'],['#5C2E2E','#9A2D2D'],
    ['#2E3D4A','#4A6A8A'],['#3D4A2E','#6A8A4A'],['#4A2E3D','#8A4A6A'],
    ['#3D2828','#8A5A2D'],['#282E4A','#4A5A8A'],['#2E4A28','#5A8A4A'],
  ];
  let h = 0;
  for (let i = 0; i < titre.length; i++) h = (h * 31 + titre.charCodeAt(i)) & 0xffff;
  const [c1, c2] = p[h % p.length];
  return `linear-gradient(${120 + (h % 80)}deg, ${c1} 0%, ${c2} 100%)`;
}

const produitsJson = JSON.stringify(produits.map(p => ({
  id: p.id, titre: p.titre, affichiste: p.affichiste,
  annee: p.annee, categorie: p.categorie, theme: p.theme,
  format: p.format, ref: p.ref, etat: p.etat,
  stk_e: p.stk_e, stk_p: p.stk_p, stk_c: p.stk_c,
  color: posterColor(p.titre),
})));
---

<BaseLayout
  title="Collection — L'Affiche Entoilée"
  description="Sélection d'affiches originales restaurées et entoilées par Hervé."
>

<!-- ── HEADER ──────────────────────────────────── -->
<header class="gallery-header">
  <div>
    <span class="eyebrow">Collection</span>
    <h1>Affiches originales</h1>
    <p class="gallery-subtitle">Laissez-vous guider vers la pièce qui vous correspond,<br>ou explorez la collection dans son intégralité.</p>
  </div>
  <div class="header-actions">
    <span class="gallery-count">{produits.length} pièces</span>
    <button id="btn-skip" class="btn-ghost-small">Voir toute la collection →</button>
  </div>
</header>

<!-- ── QUESTIONNAIRE ──────────────────────────── -->
<section id="quiz-section">
  <div class="quiz-wrap">

    <!-- Progression -->
    <div class="quiz-progress">
      <div class="quiz-progress-meta">
        <span class="quiz-progress-label">Trouver mon affiche</span>
        <span class="quiz-progress-count"><span id="q-num">1</span> / 4</span>
      </div>
      <div class="quiz-bar"><div class="quiz-bar-fill" id="q-bar" style="width:25%"></div></div>
    </div>

    <!-- Question -->
    <div class="quiz-body">
      <h2 class="quiz-question" id="quiz-question"></h2>
      <div class="quiz-options" id="quiz-options"></div>
    </div>

  </div>
</section>

<!-- ── RÉSULTATS ─────────────────────────────────── -->
<section id="results-section" class="hidden">

  <div class="results-header">
    <div>
      <p class="step-label">Sélection personnalisée</p>
      <h2 class="results-title">Trois affiches pour vous</h2>
    </div>
    <div class="results-actions">
      <button id="btn-reshuffle" class="btn-ghost-small" title="Nouvelle sélection dans les mêmes critères">↺ Autre sélection</button>
      <button id="btn-reset" class="btn-ghost-small">← Recommencer</button>
    </div>
  </div>

  <div class="results-grid" id="results-grid"></div>

  <!-- Historique des sélections -->
  <div id="history-wrap" class="history-wrap hidden">
    <p class="step-label">Vos sélections précédentes</p>
    <div class="history-list" id="history-list"></div>
  </div>

  <div class="results-footer">
    <p>Ces pièces ont été choisies selon vos réponses. La collection complète en réserve bien d'autres.</p>
    <button id="btn-all" class="btn-primary">Voir toute la collection</button>
  </div>

</section>

<!-- ── COLLECTION COMPLÈTE ───────────────────────── -->
<section id="full-section" class="hidden">
  <div class="full-header">
    <span class="gallery-count">{produits.length} affiches en collection</span>
    <button id="btn-back-chat" class="btn-ghost-small">← Retour au guide</button>
  </div>
  <div class="gallery-grid" id="gallery-grid">
    {produits.map((p, i) => (
      <article class={`gallery-item ${i % 7 === 0 ? 'gallery-item--featured' : ''}`}>
        <a href={`/produits/${p.id}`} class="gallery-link">
          <div class="gallery-visual" style={`background:${posterColor(p.titre)};`}>
            <div class="gallery-grain"></div>
            <div class="gallery-placeholder-text">
              <span class="gallery-placeholder-title">{p.titre}</span>
              {p.annee && <span class="gallery-placeholder-year">{p.annee}</span>}
            </div>
            {p.etat && <div class="gallery-badge">{p.etat}</div>}
            <div class="gallery-overlay"><span class="gallery-overlay-cta">Voir la fiche →</span></div>
          </div>
          <div class="gallery-caption">
            <div class="gallery-caption-top">
              <h2 class="gallery-title">{p.titre}</h2>
              {p.ref && <span class="gallery-ref">{p.ref}</span>}
            </div>
            <div class="gallery-caption-bottom">
              {p.affichiste && <span class="gallery-artist">{p.affichiste}</span>}
              <div class="gallery-meta-row">
                {p.annee && <span class="gallery-year">{p.annee}</span>}
                {p.categorie && <span class="gallery-cat">{p.categorie}</span>}
              </div>
            </div>
          </div>
        </a>
      </article>
    ))}
  </div>
</section>

<section class="gallery-cta">
  <p>Vous recherchez une pièce spécifique ou souhaitez confier une affiche à l'atelier ?</p>
  <a href="/contact" class="btn-primary">Contacter Hervé</a>
</section>

</BaseLayout>

<script type="application/json" id="produits-data" set:html={produitsJson}></script>

