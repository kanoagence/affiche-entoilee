<script>
// ── Données ──────────────────────────────────────────
const PRODUITS: any[] = JSON.parse(
  document.getElementById('produits-data')?.textContent ?? '[]'
);

// ── État ─────────────────────────────────────────────
const answers: Record<string, string> = {};
let currentAnswers: any[] = [];

// ── Questions ────────────────────────────────────────
const STEPS = [
  {
    key: 'periode',
    question: "Quelle époque vous attire ?",
    options: [
      { value: 'avant-1950', label: "L'âge d'or", sub: "Avant 1950 — affiches de l'entre-deux-guerres" },
      { value: '1950-1970',  label: "Les Trente Glorieuses", sub: "1950–1970 — modernisme et couleurs franches" },
      { value: '1970+',      label: "L'ère du cinéma", sub: "Années 70 et au-delà" },
      { value: 'tout',       label: "Peu importe", sub: "Je m'ouvre à toutes les périodes" },
    ]
  },
  {
    key: 'univers',
    question: "Quel univers vous parle le plus ?",
    options: [
      { value: 'cinema',    label: "Cinéma", sub: "Films cultes, acteurs, réalisateurs" },
      { value: 'voyage',    label: "Voyage & tourisme", sub: "Destinations, compagnies, mer et montagne" },
      { value: 'spectacle', label: "Spectacle & culture", sub: "Théâtre, musique, expositions" },
      { value: 'publicite', label: "Publicité vintage", sub: "Marques, produits, affiches commerciales" },
      { value: 'tout',      label: "Tout m'intéresse", sub: "Surprenez-moi" },
    ]
  },
  {
    key: 'etat',
    question: "Quel état recherchez-vous ?",
    options: [
      { value: 'A',    label: "État exceptionnel", sub: "Très bel état de conservation — A ou A+" },
      { value: 'B',    label: "Très bon état", sub: "Quelques légères marques du temps — B ou B+" },
      { value: 'tout', label: "Peu importe", sub: "L'histoire portée par la pièce compte davantage" },
    ]
  },
  {
    key: 'usage',
    question: "Pour quelle occasion ?",
    options: [
      { value: 'deco',           label: "Décoration intérieure", sub: "Une pièce maîtresse pour mon intérieur" },
      { value: 'collection',     label: "Collection personnelle", sub: "J'accumule avec passion et méthode" },
      { value: 'cadeau',         label: "Offrir", sub: "Un cadeau original et mémorable" },
      { value: 'investissement', label: "Investissement", sub: "Une valeur sûre qui s'apprécie" },
    ]
  },
];

let stepIndex = 0;
const LETTERS = ['A', 'B', 'C', 'D', 'E'];

// ── Rendu du questionnaire ────────────────────────────
function renderStep(): void {
  const step = STEPS[stepIndex];

  // Progression
  document.getElementById('q-num')!.textContent = String(stepIndex + 1);
  (document.getElementById('q-bar') as HTMLElement).style.width =
    `${((stepIndex + 1) / STEPS.length) * 100}%`;

  // Question
  const qEl = document.getElementById('quiz-question')!;
  qEl.textContent = step.question;

  // Options
  const optEl = document.getElementById('quiz-options')!;
  optEl.innerHTML = '';
  step.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-opt';
    btn.style.animationDelay = `${i * 0.05}s`;
    btn.innerHTML = `
      <span class="quiz-opt-letter">${LETTERS[i]}</span>
      <span class="quiz-opt-body">
        <span class="quiz-opt-label">${opt.label}</span>
        ${opt.sub ? `<span class="quiz-opt-sub">${opt.sub}</span>` : ''}
      </span>
      <span class="quiz-opt-arrow">→</span>`;
    btn.addEventListener('click', () => onSelect(opt));
    optEl.appendChild(btn);
  });

  // Animation du bloc
  const body = document.querySelector('.quiz-body') as HTMLElement;
  body.style.animation = 'none';
  void body.offsetWidth;
  body.style.animation = 'fadeSlideUp 0.3s ease both';
}

function onSelect(opt: any): void {
  answers[STEPS[stepIndex].key] = opt.value;
  stepIndex++;
  if (stepIndex < STEPS.length) {
    renderStep();
  } else {
    showResults(false);
  }
}

function startQuiz(): void {
  stepIndex = 0;
  Object.keys(answers).forEach(k => delete answers[k]);
  document.getElementById('quiz-section')!.classList.remove('hidden');
  renderStep();
}

// ── Sélection & résultats ────────────────────────────

function getYear(annee: string | null): number {
  if (!annee) return 0;
  const m = annee.match(/\d{4}/);
  return m ? parseInt(m[0]) : 0;
}

function matchPeriode(p: any): boolean {
  const v = answers['periode'];
  if (!v || v === 'tout') return true;
  const y = getYear(p.annee);
  if (!y) return true;
  if (v === 'avant-1950') return y < 1950;
  if (v === '1950-1970') return y >= 1950 && y <= 1970;
  if (v === '1970+') return y > 1970;
  return true;
}

function matchUnivers(p: any): boolean {
  const v = answers['univers'];
  if (!v || v === 'tout') return true;
  const hay = ((p.categorie ?? '') + ' ' + (p.theme ?? '')).toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  if (v === 'cinema') return hay.includes('cin') || hay.includes('film') || hay.includes('court');
  if (v === 'voyage') return hay.includes('voyage') || hay.includes('touris') || hay.includes('transport');
  if (v === 'spectacle') return hay.includes('spectac') || hay.includes('theatre') || hay.includes('music') || hay.includes('expo');
  if (v === 'publicite') return hay.includes('public') || hay.includes('marque') || hay.includes('produit');
  return false;
}

function matchEtat(p: any): boolean {
  const v = answers['etat'];
  if (!v || v === 'tout') return true;
  const e = (p.etat ?? '').toString().trim();
  if (v === 'A') return e.startsWith('A');
  if (v === 'B') return e.startsWith('B');
  return true;
}

function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function computeSelection(exclude: any[] = []): any[] {
  const excludeIds = new Set(exclude.map(p => p.id));
  let pool = PRODUITS.filter(p => !excludeIds.has(p.id));

  let matches = pool.filter(p => matchPeriode(p) && matchUnivers(p) && matchEtat(p));
  if (matches.length < 3) matches = pool.filter(p => matchPeriode(p) && matchUnivers(p));
  if (matches.length < 3) matches = pool.filter(p => matchPeriode(p));
  if (matches.length < 3) matches = [...pool];

  return shuffle(matches).slice(0, 3);
}

function renderCard(p: any): string {
  return `
    <div class="result-card">
      <a href="/produits/${p.id}" class="result-link">
        <div class="result-visual" style="background:${p.color};">
          <div class="result-grain"></div>
          <div class="result-placeholder">
            <span class="result-placeholder-title">${p.titre}</span>
            ${p.annee ? `<span class="result-placeholder-year">${p.annee}</span>` : ''}
          </div>
          ${p.etat ? `<div class="result-badge">${p.etat}</div>` : ''}
          <div class="result-overlay"><span class="result-overlay-cta">Voir la fiche →</span></div>
        </div>
        <div class="result-caption">
          <h2 class="result-title">${p.titre}</h2>
          ${p.affichiste ? `<span class="result-artist">${p.affichiste}</span>` : ''}
          <div class="result-meta">
            ${p.annee ? `<span class="result-year">${p.annee}</span>` : ''}
            ${p.categorie ? `<span class="result-cat">${p.categorie}</span>` : ''}
          </div>
        </div>
      </a>
    </div>`;
}

// ── Historique (localStorage) ────────────────────────
type HistoryEntry = { ts: number; answers: Record<string,string>; selection: any[] };
const HISTORY_KEY = 'ae_selection_history';

function loadHistory(): HistoryEntry[] {
  try { return JSON.parse(localStorage.getItem(HISTORY_KEY) ?? '[]'); }
  catch { return []; }
}
function saveToHistory(sel: any[]): void {
  const h = loadHistory();
  h.unshift({ ts: Date.now(), answers: { ...answers }, selection: sel });
  localStorage.setItem(HISTORY_KEY, JSON.stringify(h.slice(0, 8)));
}
function renderHistory(): void {
  const h = loadHistory();
  const wrap = document.getElementById('history-wrap')!;
  const list = document.getElementById('history-list')!;
  if (h.length < 2) { wrap.classList.add('hidden'); return; }

  wrap.classList.remove('hidden');
  list.innerHTML = h.slice(1).map((entry, i) => {
    const time = new Date(entry.ts).toLocaleDateString('fr-FR', { day:'numeric', month:'long', hour:'2-digit', minute:'2-digit' });
    const thumbs = entry.selection.map(p =>
      `<div class="history-thumb" style="background:${p.color};"></div>`
    ).join('');
    const titles = entry.selection.map(p => p.titre).join(' · ');
    return `
      <div class="history-entry" data-idx="${i + 1}">
        <div class="history-thumbs">${thumbs}</div>
        <div class="history-info">
          <div class="history-time">${time}</div>
          <div class="history-titles">${titles}</div>
        </div>
        <span class="history-restore">Revoir →</span>
      </div>`;
  }).join('');

  list.querySelectorAll<HTMLElement>('.history-entry').forEach(el => {
    el.addEventListener('click', () => {
      const idx = parseInt(el.dataset.idx ?? '0');
      const entry = h[idx];
      if (!entry) return;
      document.getElementById('results-grid')!.innerHTML = entry.selection.map(renderCard).join('');
      window.scrollTo({ top: document.getElementById('results-section')!.offsetTop - 80, behavior: 'smooth' });
    });
  });
}

function showResults(isShuffle: boolean): void {
  if (!isShuffle) {
    currentAnswers = computeSelection();
    saveToHistory(currentAnswers);
  } else {
    currentAnswers = computeSelection(currentAnswers);
    saveToHistory(currentAnswers);
  }

  document.getElementById('results-grid')!.innerHTML = currentAnswers.map(renderCard).join('');
  renderHistory();

  document.getElementById('quiz-section')!.classList.add('hidden');
  document.getElementById('results-section')!.classList.remove('hidden');
  document.getElementById('full-section')!.classList.add('hidden');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── Boutons ──────────────────────────────────────────
document.getElementById('btn-reshuffle')?.addEventListener('click', () => {
  showResults(true);
});

document.getElementById('btn-reset')?.addEventListener('click', () => {
  document.getElementById('results-section')!.classList.add('hidden');
  document.getElementById('quiz-section')!.classList.remove('hidden');
  startQuiz();
  window.scrollTo({ top: document.getElementById('quiz-section')!.offsetTop - 80, behavior: 'smooth' });
});

document.getElementById('btn-all')?.addEventListener('click', () => {
  document.getElementById('results-section')!.classList.add('hidden');
  document.getElementById('full-section')!.classList.remove('hidden');
  window.scrollTo({ top: document.getElementById('full-section')!.offsetTop - 80, behavior: 'smooth' });
});

document.getElementById('btn-skip')?.addEventListener('click', () => {
  document.getElementById('quiz-section')!.classList.add('hidden');
  document.getElementById('results-section')!.classList.add('hidden');
  document.getElementById('full-section')!.classList.remove('hidden');
  window.scrollTo({ top: document.getElementById('full-section')!.offsetTop - 80, behavior: 'smooth' });
});

document.getElementById('btn-back-chat')?.addEventListener('click', () => {
  document.getElementById('full-section')!.classList.add('hidden');
  document.getElementById('quiz-section')!.classList.remove('hidden');
  window.scrollTo({ top: document.getElementById('quiz-section')!.offsetTop - 80, behavior: 'smooth' });
});

// ── Init ─────────────────────────────────────────────
startQuiz();
</script>
