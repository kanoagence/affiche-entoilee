# Exemple de configuration pour Hervé Affiches
# Copiez ce fichier en .env et adaptez les valeurs

# Secret pour les sessions (changez en production)
SESSION_SECRET=change-me-in-production-use-random-string

# Email pour les notifications de contact (optionnel)
CONTACT_EMAIL=herve@herve-affiches.fr

# Mode debug
DEBUG=false
